# Database (Supabase)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Microsoft / Azure AD (obrigatório)
# Azure Portal → App registrations → seu app → Overview
AUTH_MICROSOFT_ENTRA_ID_ID="your-azure-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-azure-client-secret"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="your-azure-tenant-id"

# Magic link (Resend ou nodemailer)
# Opcional — para magic link além do SSO Microsoft
EMAIL_FROM="Normatel <noreply@suaempresa.com.br>"
RESEND_API_KEY="re_..."

# Seed — e-mail do primeiro ADMIN criado pelo prisma/seed.ts
SEED_ADMIN_EMAIL="admin@suaempresa.com.br"
SEED_ADMIN_NAME="Administrador"
